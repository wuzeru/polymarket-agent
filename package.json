{
  "name": "polymarket-agent",
  "version": "0.1.0",
  "description": "Polymarket paper trading agent (Claude Code agent — invoke skills on demand)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "fetch": "tsx scripts/fetch-markets.ts",
    "scan": "tsx scripts/scan-arb.ts",
    "derive:clob-browser": "tsx scripts/derive-clob-browser.ts",
    "monitor:orders": "tsx scripts/monitor-market-orders.ts",
    "proposal:list": "tsx scripts/list-proposals.ts",
    "proposal:upsert": "tsx scripts/upsert-proposal.ts",
    "report": "tsx scripts/report.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "polymarket",
    "trading",
    "bot",
    "prediction-market"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "https-proxy-agent": "^9.0.0",
    "undici": "^8.2.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
