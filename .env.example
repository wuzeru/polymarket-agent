# Polymarket Agent Configuration

# Minimum profit threshold (USDC) to trigger a signal
MIN_PROFIT_THRESHOLD=0.005

# Maximum position size per trade (USDC)
MAX_POSITION_SIZE=200

# Market types to filter: single | binary | all
MARKET_TYPES=single

# Enable YES+NO arbitrage strategy
YES_NO_ARB_ENABLED=true

# Cooldown period (ms) for same token pair signal
YES_NO_ARB_COOLDOWN_MS=5000

# WebSocket reconnect delay (ms)
WS_RECONNECT_DELAY=1000

# Cache stale threshold (ms)
CACHE_STALE_THRESHOLD_MS=2000

# Virtual starting balance (USDC)
INITIAL_BALANCE=1000

# SQLite database path for persistent state
DB_PATH=data/agent-state.db

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# CLOB WebSocket URL (do not change unless instructed)
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# CLOB REST URL (do not change unless instructed)
CLOB_REST_URL=https://clob.polymarket.com

# Gamma API base URL (do not change unless instructed)
GAMMA_API_URL=https://gamma-api.polymarket.com

# Read-only order monitor
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASSPHRASE=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market/order monitor
MONITOR_EVENT_SLUG=bundesliga-top-4-finish
MONITOR_INTERVAL_MS=300000
MONITOR_PRICE_CHANGE_CENTS=5